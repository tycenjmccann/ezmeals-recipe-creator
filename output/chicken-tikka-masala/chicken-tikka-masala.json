  "ingredients": {
    "L": [
      {
        "S": "1 1/2 pounds boneless, skinless Chicken Thighs, cut into bite-sized pieces"
      },
      {
        "S": "3/4 cup Plain Greek Yogurt (full-fat)"
      },
      {
        "S": "2 tablespoons Lemon Juice"
      },
      {
        "S": "1 1/2 tablespoons Garlic, minced (about 4 to 5 cloves, for marinade)"
      },
      {
        "S": "1 tablespoon Fresh Ginger, minced or grated (for marinade)"
      },
      {
        "S": "2 teaspoons Ground Cumin (for marinade)"
      },
      {
        "S": "1 teaspoon Garam Masala (for marinade)"
      },
      {
        "S": "1 teaspoon Paprika (for marinade)"
      },
      {
        "S": "1 teaspoon Ground Coriander (for marinade)"
      },
      {
        "S": "1/2 teaspoon Turmeric (for marinade)"
      },
      {
        "S": "1/2 teaspoon Ground Cinnamon"
      },
      {
        "S": "1/4 teaspoon Cayenne Pepper (adjust to taste)"
      },
      {
        "S": "1/2 teaspoon Black Pepper"
      },
      {
        "S": "1 teaspoon Salt (for marinade)"
      },
      {
        "S": "1 tablespoon Vegetable Oil (for marinade)"
      },
      {
        "S": "2 tablespoons Butter or Ghee (for sauce)"
      },
      {
        "S": "2 tablespoons Vegetable Oil (for sauce), plus 1 to 2 tablespoons for charring"
      },
      {
        "S": "1 large Yellow Onion, finely diced"
      },
      {
        "S": "1 tablespoon Fresh Ginger, minced or grated (for sauce)"
      },
      {
        "S": "3 cloves Garlic, minced (for sauce)"
      },
      {
        "S": "2 teaspoons Ground Cumin (for sauce)"
      },
      {
        "S": "2 teaspoons Paprika (for sauce)"
      },
      {
        "S": "1 teaspoon Ground Coriander (for sauce)"
      },
      {
        "S": "1 teaspoon Turmeric (for sauce)"
      },
      {
        "S": "1 tablespoon Garam Masala (for sauce)"
      },
      {
        "S": "1 teaspoon Salt (for sauce)"
      },
      {
        "S": "1 (14 ounce) can Tomato Sauce or tomato passata"
      },
      {
        "S": "1/2 cup Water"
      },
      {
        "S": "1 cup Heavy Cream or full-fat coconut milk"
      },
      {
        "S": "1 teaspoon Sugar"
      },
      {
        "S": "2 tablespoons cold Butter, for finishing (optional but recommended)"
      },
      {
        "S": "1/4 cup Fresh Cilantro, chopped (divided - half stirred in, half for garnish)"
      },
      {
        "S": "5 cups hot cooked Basmati Rice (about 1 cup per serving)"
      },
      {
        "S": "Naan Bread (for serving)"
      },
      {
        "S": "1 Lemon, cut into wedges (optional, for serving)"
      }
    ]
  },
