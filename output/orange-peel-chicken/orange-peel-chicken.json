  "ingredients": {
    "L": [
      {
        "S": "1 pound boneless skinless chicken breasts, cut into bite-sized pieces (about 1-inch)"
      },
      {
        "S": "1/2 cup cornstarch"
      },
      {
        "S": "2 tablespoons vegetable or canola oil (plus more as needed for batches)"
      },
      {
        "S": "1/2 cup orange juice"
      },
      {
        "S": "1 teaspoon orange zest"
      },
      {
        "S": "3 cloves garlic, minced"
      },
      {
        "S": "2-4 teaspoons Sriracha hot sauce (to taste)"
      },
      {
        "S": "1/3 cup low-sodium chicken broth"
      },
      {
        "S": "2 tablespoons low-sodium soy sauce"
      },
      {
        "S": "2 tablespoons granulated sugar"
      },
      {
        "S": "2 teaspoons apple cider vinegar"
      },
      {
        "S": "1 tablespoon rice wine vinegar"
      },
      {
        "S": "2 1/2 teaspoons cornstarch"
      },
      {
        "S": "Hot cooked brown rice"
      },
      {
        "S": "4 green onions, chopped (divided - most for the stir-fry, some reserved for garnish)"
      },
      {
        "S": "Sesame seeds (optional garnish)"
      }
    ]
  },
