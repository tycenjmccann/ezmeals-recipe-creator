  "ingredients": {
    "L": [
      {
        "S": "-- For the Stew --"
      },
      {
        "S": "8 ounces Bacon, chopped into 1/4-inch strips"
      },
      {
        "S": "1/3 cup All-Purpose Flour (for dredging)"
      },
      {
        "S": "2 1/2 pounds boneless Chuck Beef, trimmed of excess fat and cut into 1 1/2-inch cubes"
      },
      {
        "S": "1 1/2 teaspoons Kosher Salt, plus more to taste"
      },
      {
        "S": "1 teaspoon Freshly Ground Black Pepper, plus more to taste"
      },
      {
        "S": "2 tablespoons Olive Oil"
      },
      {
        "S": "1 large Yellow Onion, chopped"
      },
      {
        "S": "2 stalks Celery, cut into 1/2-inch pieces"
      },
      {
        "S": "5 cloves Garlic, minced"
      },
      {
        "S": "2 tablespoons Tomato Paste"
      },
      {
        "S": "1 tablespoon Red Wine Vinegar"
      },
      {
        "S": "2 cups dry Red Wine (such as Cabernet Sauvignon, Merlot, or Cotes du Rhone)"
      },
      {
        "S": "3 cups Low-Sodium Beef Broth"
      },
      {
        "S": "2 teaspoons Better Than Bouillon Beef base"
      },
      {
        "S": "1 teaspoon Worcestershire Sauce"
      },
      {
        "S": "2 Bay Leaves"
      },
      {
        "S": "1 teaspoon chopped fresh Rosemary (or 1/2 teaspoon dried)"
      },
      {
        "S": "1 teaspoon fresh Thyme leaves (or 1/2 teaspoon dried)"
      },
      {
        "S": "4 large Carrots, peeled, sliced diagonally into 1-inch chunks"
      },
      {
        "S": "1 pound small gold, red, or fingerling Potatoes, halved or quartered into bite-sized pieces"
      },
      {
        "S": "8 ounces frozen whole Pearl Onions (optional)"
      },
      {
        "S": "8 ounces white or cremini Mushrooms, quartered (optional but recommended)"
      },
      {
        "S": "Fresh Parsley, chopped, for garnish"
      },
      {
        "S": "-- Optional Thickening --"
      },
      {
        "S": "2 tablespoons All-Purpose Flour (for thickening)"
      },
      {
        "S": "1/4 cup cold Water (for thickening)"
      }
    ]
  },
