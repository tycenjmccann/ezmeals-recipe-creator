  "ingredients": {
    "L": [
      {
        "S": "2 tablespoons olive oil (or neutral oil such as vegetable or peanut oil)"
      },
      {
        "S": "2 shallots, thinly sliced"
      },
      {
        "S": "6 cloves garlic, thinly sliced"
      },
      {
        "S": "1 tablespoon fresh ginger, minced"
      },
      {
        "S": "1/2 bell pepper, thinly sliced"
      },
      {
        "S": "1 pound ground chicken (lean ground chicken, diced chicken breast, or ground turkey)"
      },
      {
        "S": "2 teaspoons light brown sugar"
      },
      {
        "S": "1 tablespoon fish sauce (or substitute hoisin sauce)"
      },
      {
        "S": "1/4 cup low-sodium soy sauce"
      },
      {
        "S": "1 tablespoon oyster sauce"
      },
      {
        "S": "2 tablespoons Asian garlic chili sauce (such as Sambal Oelek)"
      },
      {
        "S": "1/2 cup low-sodium chicken broth"
      },
      {
        "S": "1/4 cup water"
      },
      {
        "S": "1 teaspoon cornstarch"
      },
      {
        "S": "2/3 cup fresh Thai basil leaves (or Italian basil)"
      },
      {
        "S": "Cooked jasmine rice, for serving"
      }
    ]
  },
