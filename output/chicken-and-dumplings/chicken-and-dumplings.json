  "ingredients": {
    "L": [
      {
        "S": "-- For the Soup --"
      },
      {
        "S": "2 tablespoons Olive Oil"
      },
      {
        "S": "2 Celery ribs, diced (about 1 cup)"
      },
      {
        "S": "2 large Carrots, peeled and diced (about 1 cup)"
      },
      {
        "S": "1 medium Yellow Onion, chopped (about 1 cup)"
      },
      {
        "S": "3 cloves Garlic, minced"
      },
      {
        "S": "5 tablespoons Unsalted Butter"
      },
      {
        "S": "1/3 cup All-Purpose Flour"
      },
      {
        "S": "6 cups Low-Sodium Chicken Broth"
      },
      {
        "S": "4 teaspoons Chicken Bouillon Paste"
      },
      {
        "S": "1/2 teaspoon Dried Thyme"
      },
      {
        "S": "1/2 teaspoon Dried Sage"
      },
      {
        "S": "1/4 teaspoon Dried Rosemary, crushed"
      },
      {
        "S": "1 Bay Leaf"
      },
      {
        "S": "1 teaspoon Kosher Salt, adjust to taste"
      },
      {
        "S": "1/2 teaspoon Freshly Ground Black Pepper"
      },
      {
        "S": "1 1/2 pounds Boneless Skinless Chicken Breasts or thighs"
      },
      {
        "S": "1 can (12 oz) Evaporated Milk"
      },
      {
        "S": "1/2 cup Frozen Peas"
      },
      {
        "S": "Fresh Parsley, chopped, for garnish"
      },
      {
        "S": "-- For the Dumplings --"
      },
      {
        "S": "1 2/3 cups All-Purpose Flour"
      },
      {
        "S": "1 tablespoon Baking Powder"
      },
      {
        "S": "1/2 teaspoon Kosher Salt"
      },
      {
        "S": "3/4 cup Whole Milk"
      },
      {
        "S": "1/4 cup Sour Cream"
      },
      {
        "S": "2 tablespoons Butter, melted and slightly cooled"
      }
    ]
  },
