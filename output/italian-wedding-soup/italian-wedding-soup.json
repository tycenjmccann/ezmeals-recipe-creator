  "ingredients": {
    "L": [
      {
        "S": "-- For the Meatballs --"
      },
      {
        "S": "8 oz Lean Ground Beef (80/20 or 85/15)"
      },
      {
        "S": "8 oz Ground Pork (or mild Italian sausage, casing removed)"
      },
      {
        "S": "1/3 cup plain Breadcrumbs (or fresh breadcrumbs from rustic bread)"
      },
      {
        "S": "1/4 cup freshly grated Parmesan Cheese"
      },
      {
        "S": "2 tablespoons chopped fresh Italian Parsley"
      },
      {
        "S": "3/4 teaspoon Dried Oregano (or 1 1/2 teaspoons fresh minced oregano)"
      },
      {
        "S": "3/4 teaspoon Salt"
      },
      {
        "S": "1/4 teaspoon Freshly Ground Black Pepper"
      },
      {
        "S": "1 large Egg"
      },
      {
        "S": "1 tablespoon Olive Oil (for browning)"
      },
      {
        "S": "-- For the Soup --"
      },
      {
        "S": "1 tablespoon Olive Oil"
      },
      {
        "S": "1 medium Yellow Onion, diced (about 1 1/4 cups)"
      },
      {
        "S": "3 medium Carrots, peeled and diced (about 1 1/4 cups)"
      },
      {
        "S": "3 stalks Celery, diced (about 3/4 cup)"
      },
      {
        "S": "4 cloves Garlic, minced"
      },
      {
        "S": "1 teaspoon Italian Seasoning"
      },
      {
        "S": "8 cups Low-Sodium Chicken Broth (homemade preferred)"
      },
      {
        "S": "3/4 cup acini di pepe, ditalini, or orzo pasta"
      },
      {
        "S": "5 oz (about 5 cups loosely packed) fresh Baby Spinach"
      },
      {
        "S": "-- For Serving --"
      },
      {
        "S": "Freshly Grated Parmesan Cheese"
      },
      {
        "S": "Crusty Artisan Bread"
      },
      {
        "S": "Freshly Ground Black Pepper"
      },
      {
        "S": "Optional: 1 Parmesan Cheese Rind (simmer in broth for extra depth)"
      }
    ]
  },
