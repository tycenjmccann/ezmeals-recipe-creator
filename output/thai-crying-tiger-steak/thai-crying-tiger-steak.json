  "ingredients": {
    "L": [
      {
        "S": "-- For the Steak and Marinade --"
      },
      {
        "S": "1 1/3 to 1 3/4 pounds Grilling Steak (ribeye, striploin, or flank steak, 1 to 1 1/2 inches thick)"
      },
      {
        "S": "1 tablespoon Soy Sauce"
      },
      {
        "S": "1 tablespoon Oyster Sauce"
      },
      {
        "S": "1 tablespoon Neutral Oil (vegetable, peanut, or canola)"
      },
      {
        "S": "1 tablespoon Palm Sugar, finely chopped (or Light Brown Sugar)"
      },
      {
        "S": "3 cloves Garlic, minced"
      },
      {
        "S": "1/4 teaspoon ground White Pepper (or Black Pepper)"
      },
      {
        "S": "2 tablespoons Neutral Oil, for cooking (if pan-searing)"
      },
      {
        "S": "-- For the Toasted Rice Powder --"
      },
      {
        "S": "2 tablespoons uncooked glutinous (sticky) Rice grains"
      },
      {
        "S": "-- For the Nam Jim Jaew Dipping Sauce --"
      },
      {
        "S": "2 tablespoons fresh Lime Juice (about 1 to 2 Limes)"
      },
      {
        "S": "2 tablespoons Fish Sauce"
      },
      {
        "S": "1 tablespoon Tamarind Paste (seedless, concentrate)"
      },
      {
        "S": "1 tablespoon Palm Sugar, finely chopped (or Light Brown Sugar)"
      },
      {
        "S": "1 to 2 tablespoons Toasted Rice Powder (from above)"
      },
      {
        "S": "1 to 3 teaspoons Thai Chili Flakes (phrik pon), adjust to taste"
      },
      {
        "S": "1 small Shallot, thinly sliced"
      },
      {
        "S": "1 tablespoon chopped fresh Cilantro (leaves and stems)"
      },
      {
        "S": "-- For Serving --"
      },
      {
        "S": "Sticky Rice (glutinous rice)"
      },
      {
        "S": "Fresh raw vegetables: Cabbage wedges, Thai Basil, Long Beans, Cucumber slices, Mint sprigs"
      }
    ]
  },
