  "instructions": {
    "L": [
      {
        "S": "Char the aromatics by placing a large dry pot or Dutch oven over medium-high heat. Add 1 large quartered onion and 2 halved ginger pieces cut-side down. Cook for about 4 minutes, turning occasionally, until charred in spots and fragrant."
      },
      {
        "S": "Build the broth by adding 6 cups broth, 2 cups water, 1/4 tsp ground coriander, 1 whole clove, 1 1/2 Tbsp fish sauce, 1/4 tsp hoisin sauce, 1/4 tsp soy sauce, 1/4 tsp red chili paste, 1 cinnamon stick, and a pinch of salt and pepper to the pot. Bring to a slow boil, then reduce heat to low and simmer uncovered for 30 minutes."
      },
      {
        "S": "Prepare noodles by cooking 8 oz rice vermicelli noodles according to package instructions (typically soaked in boiling water for 3-5 minutes). Once tender but not mushy, drain, rinse under cold water to stop cooking, and set aside."
      },
      {
        "S": "Prep garnishes by arranging cilantro, Thai basil, green onions, bean sprouts, lime wedges, and sliced chilies in individual small bowls for the table."
      },
      {
        "S": "Remove aromatics using tongs or a slotted spoon to discard the ginger, clove, cinnamon stick, and onion pieces from the simmering broth."
      },
      {
        "S": "Cook the protein by adding your thinly sliced meat directly to the simmering broth: allow 2-3 minutes for thinly sliced chicken or pork, 1-2 minutes for shrimp until pink and curled, or 30-60 seconds for paper-thin steak slices."
      },
      {
        "S": "Assemble by dividing the cooked noodles among 6 bowls. Ladle the hot broth and cooked protein over the noodles. Serve immediately with garnishes on the side for customization."
      }
    ]
  },
  "notes": {
    "L": [
      {
        "S": "For gluten-free: use tamari instead of soy sauce, gluten-free hoisin sauce, and ensure fish sauce is gluten-free certified."
      },
      {
        "S": "Slice all meats as thinly as possible - partially freezing steak for 20-30 minutes makes slicing easier."
      },
      {
        "S": "Fish sauce brands vary in saltiness - start with 1 Tablespoon, taste after simmering, then add more as needed."
      },
      {
        "S": "For authentic beef pho, place raw paper-thin steak slices directly into serving bowls and pour boiling broth over them."
      }
    ]
  },
