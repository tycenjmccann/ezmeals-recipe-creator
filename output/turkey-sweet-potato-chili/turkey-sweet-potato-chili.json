  "ingredients": {
    "L": [
      {
        "S": "-- For the Chili --"
      },
      {
        "S": "1 tablespoon Olive Oil"
      },
      {
        "S": "1 small Yellow Onion, diced"
      },
      {
        "S": "1 Red Bell Pepper, cored, seeded, and small-diced"
      },
      {
        "S": "3 Garlic Cloves, minced"
      },
      {
        "S": "1 pound Ground Turkey (93% lean recommended)"
      },
      {
        "S": "1/2 teaspoon Kosher Salt, plus more to taste"
      },
      {
        "S": "Freshly Ground Black Pepper, to taste"
      },
      {
        "S": "2 tablespoons Tomato Paste"
      },
      {
        "S": "2 to 3 tablespoons Chili Powder"
      },
      {
        "S": "1 1/2 teaspoons Ground Cumin"
      },
      {
        "S": "1 teaspoon Smoked Paprika"
      },
      {
        "S": "1 teaspoon Dried Oregano"
      },
      {
        "S": "1/4 teaspoon Cayenne Pepper (optional, adjust to taste)"
      },
      {
        "S": "2 (14.5 ounce) cans Fire-Roasted Diced Tomatoes, with juices"
      },
      {
        "S": "2 (15 ounce) cans Kidney Beans, rinsed and drained"
      },
      {
        "S": "1 large Sweet Potato, peeled and diced into 1/2-inch cubes (about 2 cups)"
      },
      {
        "S": "1 cup Low-Sodium Chicken Broth"
      },
      {
        "S": "1 to 2 tablespoons Lime Juice (about 1 lime)"
      },
      {
        "S": "-- Toppings (optional) --"
      },
      {
        "S": "Shredded Cheddar Cheese or Pepper Jack Cheese"
      },
      {
        "S": "Thinly sliced Green Onions"
      },
      {
        "S": "Sour Cream or Plain Greek Yogurt"
      },
      {
        "S": "Sliced Jalapenos"
      },
      {
        "S": "Diced Avocado"
      },
      {
        "S": "Fresh Cilantro"
      },
      {
        "S": "Lime Wedges"
      }
    ]
  },
