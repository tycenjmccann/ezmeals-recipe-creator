  "ingredients": {
    "L": [
      {
        "S": "2 teaspoons Garam Masala"
      },
      {
        "S": "1 1/2 teaspoons Ground Cumin"
      },
      {
        "S": "1 1/2 teaspoons Smoked Paprika (or Kashmiri chili powder)"
      },
      {
        "S": "1 teaspoon Ground Coriander"
      },
      {
        "S": "1/2 teaspoon Turmeric"
      },
      {
        "S": "1/4 teaspoon Ground Cinnamon"
      },
      {
        "S": "1/4 teaspoon Cayenne Pepper (adjust to taste)"
      },
      {
        "S": "1/8 teaspoon Ground Cardamom"
      },
      {
        "S": "1 teaspoon Salt"
      },
      {
        "S": "1/2 teaspoon Black Pepper"
      },
      {
        "S": "2 pounds boneless, skinless Chicken Thighs (about 8 thighs), cut into 1 1/2-inch pieces"
      },
      {
        "S": "1 medium Yellow Onion, finely diced (about 1 cup)"
      },
      {
        "S": "4 cloves Garlic, minced"
      },
      {
        "S": "1 tablespoon Fresh Ginger, peeled and finely grated"
      },
      {
        "S": "2 (8 ounce) cans Tomato Sauce"
      },
      {
        "S": "1 (15 ounce) can Diced Tomatoes, undrained"
      },
      {
        "S": "1/4 fresh Jalapeno Pepper, seeds removed, finely chopped (optional)"
      },
      {
        "S": "1/2 teaspoon Sugar"
      },
      {
        "S": "1 cup canned unsweetened full-fat Coconut Milk, well shaken"
      },
      {
        "S": "2 teaspoons Cornstarch or tapioca starch"
      },
      {
        "S": "1 tablespoon dried Fenugreek Leaves (kasuri methi), crushed (optional but recommended)"
      },
      {
        "S": "1/4 cup fresh Cilantro, chopped"
      },
      {
        "S": "4 to 5 cups hot cooked Basmati Rice"
      },
      {
        "S": "Naan Bread (optional)"
      },
      {
        "S": "1 Lemon, cut into wedges (optional)"
      }
    ]
  },
