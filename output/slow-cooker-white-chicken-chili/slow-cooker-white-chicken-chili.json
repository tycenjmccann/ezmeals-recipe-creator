  "ingredients": {
    "L": [
      {
        "S": "-- In the Slow Cooker --"
      },
      {
        "S": "1 to 1 1/4 pounds Boneless Skinless Chicken Breasts (about 2 medium breasts)"
      },
      {
        "S": "1 Yellow Onion, finely diced (heaping 1 cup)"
      },
      {
        "S": "3 cloves Garlic, minced"
      },
      {
        "S": "1 Jalapeno, seeded and finely diced (optional)"
      },
      {
        "S": "2 (15 ounce) cans Cannellini Beans, drained and rinsed"
      },
      {
        "S": "1 (15 ounce) can Pinto Beans, drained and rinsed"
      },
      {
        "S": "1 (16 ounce) jar Salsa Verde"
      },
      {
        "S": "2 cups Low-Sodium Chicken Broth"
      },
      {
        "S": "1 cup Frozen Corn Kernels"
      },
      {
        "S": "-- Spice Blend --"
      },
      {
        "S": "1 1/2 teaspoons Ground Cumin"
      },
      {
        "S": "1 teaspoon Dried Oregano"
      },
      {
        "S": "1/2 teaspoon Ground Coriander"
      },
      {
        "S": "1/2 teaspoon Smoked Paprika"
      },
      {
        "S": "1/4 teaspoon Cayenne Pepper"
      },
      {
        "S": "1/2 teaspoon Kosher Salt, plus more to taste"
      },
      {
        "S": "1/4 teaspoon Freshly Ground Black Pepper"
      },
      {
        "S": "-- Finish (stirred in after cooking) --"
      },
      {
        "S": "4 ounces Cream Cheese or Neufchatel, softened and cut into cubes"
      },
      {
        "S": "1 tablespoon fresh Lime Juice (about 1/2 lime)"
      },
      {
        "S": "2 tablespoons chopped Fresh Cilantro (optional)"
      },
      {
        "S": "-- Toppings (optional) --"
      },
      {
        "S": "Shredded Monterey Jack or Pepper Jack Cheese"
      },
      {
        "S": "Diced Avocado"
      },
      {
        "S": "Fresh Cilantro Leaves"
      },
      {
        "S": "Lime Wedges"
      },
      {
        "S": "Sour Cream or Greek Yogurt"
      },
      {
        "S": "Tortilla Chips or strips"
      },
      {
        "S": "Sliced Scallions"
      }
    ]
  },
