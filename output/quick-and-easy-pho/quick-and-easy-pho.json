  "ingredients": {
    "L": [
      {
        "S": "8 oz dried rice vermicelli noodles"
      },
      {
        "S": "1 lb protein of choice (chicken, pork, steak, or raw shrimp), thinly sliced"
      },
      {
        "S": "1 large yellow onion, quartered"
      },
      {
        "S": "2 (2-inch) pieces fresh ginger, unpeeled and halved lengthwise"
      },
      {
        "S": "6 cups broth (chicken, beef, or vegetable, depending on protein choice)"
      },
      {
        "S": "2 cups water"
      },
      {
        "S": "1/4 tsp ground coriander"
      },
      {
        "S": "1 whole clove"
      },
      {
        "S": "1 1/2 Tablespoons fish sauce"
      },
      {
        "S": "1/4 teaspoon hoisin sauce"
      },
      {
        "S": "1/4 teaspoon soy sauce"
      },
      {
        "S": "1/4 teaspoon red chili paste (sambal oelek)"
      },
      {
        "S": "1 stick cinnamon"
      },
      {
        "S": "Salt and freshly ground black pepper, to taste"
      },
      {
        "S": "4 green onions, chopped"
      },
      {
        "S": "2 fresh jalape\u00f1o peppers or red Thai chili peppers, thinly sliced and seeds removed"
      },
      {
        "S": "1 bunch fresh cilantro, chopped"
      },
      {
        "S": "1 bunch Thai basil leaves"
      },
      {
        "S": "1 cup fresh bean sprouts"
      },
      {
        "S": "2 limes, cut into wedges"
      },
      {
        "S": "Sriracha hot sauce, for serving (optional)"
      }
    ]
  },
