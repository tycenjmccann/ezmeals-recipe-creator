  "instructions": {
    "L": [
      {
        "S": "Place a large dry pot over medium heat. Add the quartered yellow onion and 2 pieces of ginger. Cook for 4 minutes, stirring occasionally, until lightly charred."
      },
      {
        "S": "Add 6 cups broth, 2 cups water, 1/4 tsp ground coriander, 1 whole clove, 1 1/2 Tablespoons fish sauce, 1/4 teaspoon hoisin sauce, 1/4 teaspoon soy sauce, 1/4 teaspoon red chili paste, 1 cinnamon stick, and a pinch of salt and pepper to the pot. Bring to a slow boil, then reduce heat and simmer for 30 minutes."
      },
      {
        "S": "Meanwhile, prepare 8 oz rice vermicelli noodles according to package instructions. Once soft, drain, rinse with cold water, and set aside."
      },
      {
        "S": "Ready the garnishes in individual small bowls for serving: chopped cilantro, Thai basil leaves, chopped green onions, 1 cup bean sprouts, lime wedges, and sliced jalape\u00f1os or Thai chilies."
      },
      {
        "S": "1-5 minutes before the broth is done simmering, add 1 lb of your desired thinly sliced protein to the broth to cook just until done (2-3 minutes for raw thinly sliced chicken or pork, 1-2 minutes for shrimp or thinly sliced steak)."
      },
      {
        "S": "Using tongs or a slotted spoon, discard the ginger pieces, whole clove, cinnamon stick, and onion quarters from the pot."
      },
      {
        "S": "Divide the cooked noodles among 6 bowls. Ladle the hot broth and meat over the noodles. Add desired toppings and serve immediately with Sriracha on the side."
      }
    ]
  },
