  "instructions": {
    "L": [
      {
        "S": "Cook 16 oz ramen noodles according to package instructions. Drain, toss with a small drizzle of sesame oil or neutral oil to prevent sticking, and set aside."
      },
      {
        "S": "Whisk together 1/2 cup soy sauce, 1/2 cup hoisin sauce, 1/4 cup water, 2 teaspoons cornstarch, 2 teaspoons ginger, 1 Tablespoon honey, 2 teaspoons sesame oil, and 1/4 teaspoon red pepper flakes in a small bowl. Whisk well to dissolve cornstarch and re-stir just before adding to the pan, as cornstarch settles."
      },
      {
        "S": "Season 2 lb ground meat generously with salt and pepper. Heat a large wok or deep skillet over medium-high heat. Cook the meat, breaking into small pieces, until well browned, about 5-7 minutes. Push meat to the side of the pan and tilt to drain, spooning off excess grease if needed."
      },
      {
        "S": "Add 1 medium grated carrot, 1 medium diced red bell pepper, 1 1/2 cups halved snap peas, and the white parts of 4 green onions to the pan. Saut\u00e9 for 2-3 minutes until just tender-crisp. Add 6 cloves minced garlic and cook for 30 seconds until fragrant, being careful not to let it burn."
      },
      {
        "S": "Stir the vegetables and meat together. Add the drained noodles and give the sauce one final stir to re-incorporate the cornstarch, then pour over everything. Toss well over heat for 1-2 minutes until the sauce thickens and evenly coats the noodles with a glossy finish."
      },
      {
        "S": "Garnish with the green parts of the green onions and serve immediately."
      }
    ]
  },
  "notes": {
    "L": [
      {
        "S": "For gluten-free: use tamari instead of soy sauce, gluten-free hoisin sauce, and gluten-free ramen noodles or substitute with rice noodles"
      },
      {
        "S": "Use fresh or dried ramen-style wheat noodles. If using instant ramen, discard the seasoning packets. Lo mein or udon noodles also work"
      },
      {
        "S": "Always whisk the sauce again right before adding it to the pan as cornstarch settles quickly"
      },
      {
        "S": "Use the largest wok or skillet you have. If your pan is too small, consider working in batches for proper browning"
      },
      {
        "S": "For ground turkey or chicken, add 1 Tablespoon neutral oil to the pan before cooking to prevent sticking"
      },
      {
        "S": "Hoisin sauce brands vary in sweetness. Taste the sauce before adding and adjust honey accordingly"
      }
    ]
  },
