  "ingredients": {
    "L": [
      {
        "S": "1 cup Red Lentils"
      },
      {
        "S": "1 1/2 tablespoons Coconut Oil or neutral oil"
      },
      {
        "S": "1 small Yellow Onion, finely diced"
      },
      {
        "S": "4 cloves Garlic, minced"
      },
      {
        "S": "1 tablespoon Fresh Ginger, minced or grated"
      },
      {
        "S": "3/4 teaspoon Sea Salt, plus more to taste"
      },
      {
        "S": "1 teaspoon Ground Cumin"
      },
      {
        "S": "1 teaspoon Curry Powder"
      },
      {
        "S": "1/2 teaspoon Ground Coriander"
      },
      {
        "S": "1/2 teaspoon Turmeric"
      },
      {
        "S": "1/4 to 1/2 teaspoon Chili Powder or Cayenne Pepper (to taste)"
      },
      {
        "S": "1 (14 ounce) can Crushed Tomatoes (or fire-roasted crushed tomatoes)"
      },
      {
        "S": "2 cups Vegetable Broth (low-sodium recommended)"
      },
      {
        "S": "1 (14 ounce) can full-fat Coconut Milk, shaken well before opening"
      },
      {
        "S": "1 teaspoon Garam Masala"
      },
      {
        "S": "2 tablespoons Almond Butter (or cashew butter, peanut butter, or tahini)"
      },
      {
        "S": "1 1/2 tablespoons fresh Lemon Juice (about half a lemon), plus more to taste"
      },
      {
        "S": "Pinch of Sugar or maple syrup (optional, to balance acidity)"
      },
      {
        "S": "1 tablespoon Coconut Oil or neutral oil (for optional tadka)"
      },
      {
        "S": "1 teaspoon Cumin Seeds or Mustard Seed (for optional tadka)"
      },
      {
        "S": "2 cloves Garlic, thinly sliced (for optional tadka)"
      },
      {
        "S": "Pinch of Crushed Red Pepper Flakes (for optional tadka)"
      },
      {
        "S": "1 handful Fresh Cilantro, roughly chopped (for garnish)"
      },
      {
        "S": "4 cups hot cooked Basmati Rice (about 1 cup per serving)"
      },
      {
        "S": "Naan Bread or flatbread (for serving)"
      },
      {
        "S": "1 Lemon, cut into wedges (for serving)"
      }
    ]
  },
