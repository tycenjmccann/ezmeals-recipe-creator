  "ingredients": {
    "L": [
      {
        "S": "2 cups Brown Lentils, rinsed and picked over for debris"
      },
      {
        "S": "1 Yellow Onion, diced"
      },
      {
        "S": "4 cloves Garlic, minced"
      },
      {
        "S": "1 tablespoon Fresh Ginger, grated or finely minced"
      },
      {
        "S": "2 Carrots, peeled and sliced into 1/4-inch rounds"
      },
      {
        "S": "1 Sweet Potato (about 3/4 pound), peeled and diced into 1/2-inch cubes"
      },
      {
        "S": "3 tablespoons Curry Powder (hot or mild, to preference)"
      },
      {
        "S": "1 teaspoon Ground Cumin"
      },
      {
        "S": "1/2 teaspoon Turmeric"
      },
      {
        "S": "1/4 teaspoon Ground Cloves (optional)"
      },
      {
        "S": "1/4 teaspoon Cayenne Pepper (optional, omit if using hot curry powder)"
      },
      {
        "S": "1 teaspoon Kosher Salt, plus more to taste"
      },
      {
        "S": "1/4 teaspoon Black Pepper"
      },
      {
        "S": "1 (15 ounce) can petite Diced Tomatoes, with juices"
      },
      {
        "S": "1 (15 ounce) can Tomato Sauce"
      },
      {
        "S": "3 cups Vegetable Broth (low-sodium recommended)"
      },
      {
        "S": "1 (14 ounce) can full-fat Coconut Milk, shake well before opening"
      },
      {
        "S": "1 to 2 tablespoons fresh Lime Juice (about 1 lime)"
      },
      {
        "S": "10 cups cooked Basmati Rice or Jasmine Rice (about 1 cup per serving)"
      },
      {
        "S": "1/2 Red Onion, finely diced"
      },
      {
        "S": "1/2 bunch Fresh Cilantro, roughly chopped (or sliced green onions)"
      },
      {
        "S": "1 Lime, cut into wedges"
      },
      {
        "S": "Naan Bread (optional)"
      }
    ]
  },
