      {
        "S": "2 tablespoons packed parsley (flat leaf or curly)"
      },
      {
        "S": "2 tablespoons packed cilantro"
      },
      {
        "S": "4 baby carrots (or equivalent portion of a full-size carrot)"
      },
      {
        "S": "1 scallion, white and green parts, cut into 4-5 pieces"
      },
      {
        "S": "1 clove garlic"
      },
      {
        "S": "1 (15 oz) can chickpeas, drained and rinsed"
      },
      {
        "S": "2 tablespoons chickpea flour"
      },
      {
        "S": "1 teaspoon baking powder"
      },
      {
        "S": "1 1/2 tablespoons olive oil"
      },
      {
        "S": "1 tablespoon fresh lemon juice"
      },
      {
        "S": "1 tablespoon hemp seeds"
      },
      {
        "S": "1/2 tablespoon chia seeds"
      },
      {
        "S": "1 teaspoon ground flax seeds"
      },
      {
        "S": "1/2 teaspoon salt"
      },
      {
        "S": "Spray olive or avocado oil (for baking sheet)"
      },
      {
        "S": "1 cup Greek yogurt"
      },
      {
        "S": "3-4 teaspoons lemon juice (more to taste)"
      },
      {
        "S": "1 1/2 tablespoons finely chopped dill"
      },
      {
        "S": "1 clove garlic, minced"
      },
      {
        "S": "1 tablespoon finely chopped parsley"
      },
      {
        "S": "Pinch of salt"
      },
      {
        "S": "1-2 cups mixed greens or lettuce of choice"
      },
      {
        "S": "1/2 cup cucumbers, quartered, skin left on"
      },
      {
        "S": "1/3-1/2 cup cherry tomatoes, halved"
      },
      {
        "S": "1/4 cup finely chopped red onion"
      },
      {
        "S": "1 big scoop store-bought hummus"
      },
      {
        "S": "3-5 kalamata olives, to taste"
      },
      {
        "S": "1-2 tablespoons feta cheese or vegan feta, to taste"
      },
      {
        "S": "Balsamic vinegar and olive oil for drizzling, to taste"
      }
    ]
  },
  "ingredient_objects": {
    "L": []
  },
  "instructions": {
    "L": [
      {
        "S": "Preheat oven to 375°F (190°C). Line a baking sheet with parchment paper and lightly spray with olive or avocado oil."
      },
      {
        "S": "Process the aromatics in a food processor by pulsing the 2 tablespoons parsley, 2 tablespoons cilantro, 4 baby carrots, 1 scallion (cut into pieces), and 1 clove garlic until finely chopped, scraping down the sides as needed."
      },
      {
        "S": "Add the remaining falafel ingredients to the food processor: drained and rinsed chickpeas, 2 tablespoons chickpea flour, 1 teaspoon baking powder, 1 1/2 tablespoons olive oil, 1 tablespoon lemon juice, 1 tablespoon hemp seeds, 1/2 tablespoon chia seeds, 1 teaspoon ground flax seeds, and 1/2 teaspoon salt. Pulse until well combined but still textured — do NOT purée into a smooth paste."
      },
      {
        "S": "Rest the falafel mixture for 5 minutes to allow the chia and flax seeds to absorb moisture and act as binders."
      },
      {
        "S": "Shape the mixture using a spoon or small cookie scoop (about 2 tablespoons each) to form approximately 9 balls, then gently flatten into thick patties about 3/4 inch thick. Place on the prepared baking sheet."
      },
      {
        "S": "Spray the tops of the falafels lightly with olive or avocado oil spray for crispiness."
      },
      {
        "S": "Bake at 375°F for 15 minutes. Flip carefully, spray again lightly, and bake for an additional 12-15 minutes until golden brown and crispy on the outside."
      },
      {
        "S": "Make the herbed yogurt sauce by stirring together 1 cup Greek yogurt, 3-4 teaspoons lemon juice, 1 1/2 tablespoons chopped dill, 1 clove minced garlic, 1 tablespoon chopped parsley, and a pinch of salt in a small bowl. Taste and adjust seasonings as desired. Refrigerate until ready to serve."
      },
      {
        "S": "Divide the mixed greens among 3 bowls. Top each with cucumbers, cherry tomatoes, red onion, kalamata olives, and feta cheese."
      },
      {
        "S": "Add a big scoop of hummus and 3 baked falafels to each bowl."
      },
      {
        "S": "Drizzle with herbed yogurt sauce, then finish with a light drizzle of balsamic vinegar and olive oil."
      }
    ]
  },
  "notes": {
    "L": [
      {
        "S": "For gluten-free: This recipe is naturally gluten-free using chickpea flour. Can substitute gluten-free all-purpose flour or gluten-free oat flour for chickpea flour if needed."
      },
      {
        "S": "For vegan: Use Greek almond milk yogurt for the sauce and vegan feta to make the entire bowl vegan."
      },
      {
        "S": "Make-ahead: Falafel mixture can be made a day ahead and refrigerated. Recipe doubles well — freeze extra baked falafels on a sheet pan, then transfer to a bag. Reheat from frozen at 375°F for 10-12 minutes."
      },
      {
        "S": "Don't over-process the chickpeas. Pulse in short bursts; the mixture should look like coarse breadcrumbs that hold together when squeezed."
      },
      {
        "S": "Drain chickpeas thoroughly and pat them dry with a towel after rinsing. Excess moisture makes soggy falafels that won't hold together."
      }
    ]
  },
