  "ingredients": {
    "L": [
      {
        "S": "1 1/2 pounds beef (tenderloin, sirloin, flank steak, or boneless ribeye), cut into thin strips"
      },
      {
        "S": "Salt and Pepper"
      },
      {
        "S": "4 Garlic Cloves, minced"
      },
      {
        "S": "1 teaspoon Ground Cumin"
      },
      {
        "S": "1 teaspoon Dried Oregano"
      },
      {
        "S": "1 Tablespoon Olive Oil, plus more for saut\u00e9ing"
      },
      {
        "S": "2 1/2 cups chopped Red Onion, cut into thick chunks (about 2 small/med onions)"
      },
      {
        "S": "1 large Yellow Bell Pepper, cut into thin strips"
      },
      {
        "S": "2-3 Roma Tomatoes, cut into thin wedges"
      },
      {
        "S": "1/2 cup Low-Sodium Soy Sauce"
      },
      {
        "S": "1/4 cup Red Wine Vinegar"
      },
      {
        "S": "1/4 cup Oyster Sauce"
      },
      {
        "S": "1/2 cup Low-Sodium Beef Broth"
      },
      {
        "S": "Crushed Red Pepper Flakes, to taste"
      },
      {
        "S": "2/3 cup Fresh Cilantro, finely chopped"
      },
      {
        "S": "2 pounds Frozen French Fries, or yellow potatoes, cut into fries and fried"
      },
      {
        "S": "2 1/2 cups hot cooked White Rice"
      }
    ]
  },
