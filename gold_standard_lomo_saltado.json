  "instructions": {
    "L": [
      {
        "S": "Cook french fries according to package instructions or make homemade fries."
      },
      {
        "S": "Season beef slices with salt, pepper, 4 cloves minced garlic, 1 teaspoon cumin, 1 teaspoon oregano, and 1 tablespoon olive oil. Marinate for 10-15 minutes while preparing other ingredients."
      },
      {
        "S": "Heat 1-2 tablespoons olive oil in a large wok or skillet over high heat."
      },
      {
        "S": "Add the beef in batches to avoid overcrowding and stir-fry briefly for 2-3 minutes, flipping once, until browned but still juicy inside."
      },
      {
        "S": "Remove beef from pan and set aside."
      },
      {
        "S": "Add another 1-2 tablespoons oil to the pan."
      },
      {
        "S": "Add 2 1/2 cups red onion and 1 large yellow bell pepper and cook for 2-3 minutes, tossing frequently."
      },
      {
        "S": "Add 2-3 Roma tomatoes and cook for one more minute."
      },
      {
        "S": "Return the beef to the pan and add 1/2 cup soy sauce, 1/4 cup red wine vinegar, 1/4 cup oyster sauce, and 1/2 cup beef broth."
      },
      {
        "S": "Add crushed red pepper flakes to taste and stir to combine."
      },
      {
        "S": "Cook for 1-2 minutes to blend flavors."
      },
      {
        "S": "Mix in 2/3 cup fresh cilantro and remove from heat."
      },
      {
        "S": "Serve the stir-fry over hot cooked white rice with french fries on the side."
      }
    ]
  },
  "notes": {
    "L": [
      {
        "S": "Choose a tender, quick-cooking cut of beef that can handle high heat without becoming tough. Good choices are tenderloin, sirloin, flank steak, or boneless ribeye."
      },
      {
        "S": "For a gluten-free version, use gluten-free soy sauce and oyster sauce."
      }
    ]
  },
